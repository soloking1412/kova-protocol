# Solver key exported via `sui keytool export --key-identity <addr>` (bech32)
SOLVER_PRIVATE_KEY=suiprivkey1...

# Set after `scripts/deploy.sh` and `scripts/fund-solver.ts`
KOVA_PACKAGE_ID=0x...
SOLVER_RECORD_ID=0x...
FEE_COLLECTOR_ID=0x...
# REGISTRY_ID is only needed by scripts/fund-solver.ts
REGISTRY_ID=0x...

SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_GRPC_URL=https://fullnode.testnet.sui.io:443

# Only fill when the net estimate clears the user's minimum by this margin
MIN_PROFIT_BPS=5
GAS_BUDGET_MIST=100000000
POLL_INTERVAL_MS=2500

# Walrus audit log (solver wallet needs WAL; swap SUI via the Walrus exchange)
ENABLE_WALRUS=true
WALRUS_EPOCHS=1
WALRUS_UPLOAD_RELAY=https://upload-relay.testnet.walrus.space
WALRUS_TIP_MAX=1000000
